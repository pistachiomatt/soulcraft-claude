{
  "name": "Soulcraft Demo",
  "image": "mcr.microsoft.com/devcontainers/base:ubuntu-22.04",
  "features": {
    "ghcr.io/devcontainers/features/node:1": { "version": "22" },
    "ghcr.io/devcontainers/features/python:1": { "version": "3.13" }
  },
  "postCreateCommand": ".devcontainer/setup.sh",
  "postStartCommand": "code /workspaces/soulcraft-claude/evals/test-ai/behaviors/proactivity.yaml",
  "secrets": {
    "ANTHROPIC_API_KEY": {
      "description": "Anthropic API key for running evals and Claude Code"
    }
  },
  "containerEnv": {
    "ANTHROPIC_API_KEY": "${localEnv:ANTHROPIC_API_KEY}"
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "anthropics.claude-code"
      ],
      "settings": {
        "terminal.integrated.defaultProfile.linux": "Soulcraft Claude",
        "terminal.integrated.profiles.linux": {
          "Soulcraft Claude": {
            "path": "/bin/bash",
            "args": ["-c", "cd /workspaces/soulcraft-claude && echo '🎨 Welcome to Soulcraft — run the command below to start the artisan:' && echo '' && echo '  soulcraft claude --project-dir /workspaces/soulcraft-claude/evals/test-ai' && echo '' && exec bash"]
          }
        },
        "workbench.panel.defaultLocation": "right",
        "workbench.startupEditor": "none",
        "chat.enabled": false,
        "explorer.openEditors.visible": 0,
        "terminal.integrated.shellIntegration.enabled": true,
        "codespaces.showWelcome": false,
        "workbench.welcomePage.walkthroughs.openOnInstall": false
      }
    }
  },
  "forwardPorts": [7682]
}
